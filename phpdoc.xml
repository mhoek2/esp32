<?xml version="1.0" encoding="UTF-8" ?>
<phpdocumentor
    configVersion="3"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns="https://www.phpdoc.org"
    xsi:noNamespaceSchemaLocation="https://docs.phpdoc.org/latest/phpdoc.xsd"
>
    <title>ESP32 Platform Documentation</title>

    <paths>
        <output>docs/build</output>
    </paths>

    <version number="0.1.0">
        <api format="php">
            <source dsn=".">
                <path>app</path> <!-- Include the whole "app" directory -->
            </source>
            <output>api</output>

            <ignore hidden="true" symlinks="true">
                <!-- Exclude all files in app/Config except Services.php -->
                <path>app/Config/*</path>
				<path>docs/build/*</path>
            </ignore>
        </api>
        <guide>
            <source dsn=".">
                <path>docs</path>
            </source>
            <output>/guide</output>
        </guide>
    </version>

    <template name="default" />
</phpdocumentor>